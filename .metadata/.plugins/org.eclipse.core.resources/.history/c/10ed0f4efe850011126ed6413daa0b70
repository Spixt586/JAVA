package com.krakedev;

public class Calculadora {
	
	
	public int sumar(int a, int b) {
		
		int resultado;
		
		resultado = a + b;
		
		return resultado;
		
	}
	
	public int restar(int a, int b) {
		
		int resultado;
		resultado = a - b;
		
		return resultado;
	}
	
	public int multiplicar(int a, int b) {
		int resultado;
		resultado = a * b;
		
		return resultado;
	}
	
	public int dividir(int a, int b) {
		int resultado;
		resultado = a / b;
		
		return resultado;
	}
	
}
