package com.krakedev;

public class Fecha {
	private int dia;
	private int mes;
	private int anio;
	
	public int getDia() {
		return dia;
	}
	public int getMes() {
		return mes;
	}
	public int getAnio() {
		return anio;
	}
	
	public void setDia(int nuevoDia) {
		dia = nuevoDia;
	}
}
	public void setMes(int nuevoMes) {
		dia = nuevoMes;
	}
}
	public void setAnio(int nuevoAnio) {
		dia = nuevoAnio;
	}
}
